# Copiar este archivo a .env y llenar los valores
# NO subir .env a git

DATABASE_URL=sqlite:///agente_imss.db

# Credenciales por patrón (se pueden también registrar desde la UI)
# Patrón 1
PATRON_1_REGISTRO=Y0000000000
PATRON_1_USUARIO=XAXX010101000
PATRON_1_PASSWORD=tu_password_aqui
PATRON_1_CERT_PATH=C:/certs/patron1/certificado.cer

# Timeout de scraping (segundos)
SCRAPING_TIMEOUT=30
HEADLESS=true
